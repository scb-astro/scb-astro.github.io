---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout pageTitle="Presentations">
    <div class="page-container">
        <h1>Presentations</h1>

        <p class="intro-text">
            I regularly present my research at major international astronomy conferences and symposia, 
            focusing on the formation, evolution, and kinematic properties of galaxies through advanced 
            cosmological simulations.
        </p>

        <section>
            <h2>Talks</h2>
            <ul class="custom-list">
                <li>
                    <span class="list-item-title">
                        Disks Without Bulges Host Distinct Satellite Populations
                    </span>
                    <span class="list-item-description">
                        BeyondHubble: Revisiting the Hubble Sequence Across Cosmic Time — Kavli Institute for Cosmology in Cambridge, UK, April 2026 
                    </span>
                </li>
                <li>
                    <span class="list-item-title">
                        BEARD in Illustris: the satellite galaxy population
                    </span>
                    <span class="list-item-description">
                        Cosmic Evolution of Milky Way-like galaxies (CEMWAY) — San Cristóbal de La Laguna, Tenerife, Spain, March 2025 
                    </span>
                </li>
                <li>
                    <span class="list-item-title">
                        The Role of Host Galaxy Morphology in Shaping Satellite Populations
                    </span>
                    <span class="list-item-description">
                        Bulgeless Evolution And the Rise of the Discs (BEARD) — Online, April 2025 
                    </span>
                </li>
                <li>
                    <span class="list-item-title">
                        Metallicity gradients on simulated Ultra Diffuse galaxies
                    </span>
                    <span class="list-item-description">
                        Hiking through the unexplored Universe: the sunrise of Ultra diffuse galaxies — Sexten-Sesto, Italy, June 2023 
                    </span>
                </li>
                <li>
                    <span class="list-item-title">
                        Metallicity gradients of Ultra Diffuse Galaxies in NIHAO Simulations
                    </span>
                    <span class="list-item-description">
                        XV Reunión de la Sociedad Española de Astronomía — San Cristóbal de La Laguna, September 2022 
                    </span>
                </li>
                <li>
                    <span class="list-item-title">
                        Dispersion vs Rotation Support in Ultra-Diffuse and Low Surface Brightness Galaxies
                    </span>
                    <span class="list-item-description">
                        IAU Symposium 355 "The Realm of the Low Surface Brightness Universe" — Tenerife, Spain, July 2021 
                    </span>
                </li>
            </ul>
        </section>

        <section>
            <h2>Posters</h2>
            <ul class="custom-list">
                <li>
                    <span class="list-item-title">
                        Exploring the Satellite Systems of Bulge-Less Galaxies: Insights from TNG50
                    </span>
                    <span class="list-item-description">
                        Galactic ecosystems under the microscope: lessons from highly-resolved studies — Garching, Germany, July 2025 (DOI: 10.5281/zenodo.18474337) 
                    </span>
                </li>
                <li>
                    <span class="list-item-title">
                        Metallicity gradients of Ultra Diffuse Galaxies in NIHAO Simulations
                    </span>
                    <span class="list-item-description">
                        European Astronomical Society Annual Meeting — Valencia, Spain, June 2022
                    </span>
                </li>
            </ul>
        </section>
    </div>
</Layout>